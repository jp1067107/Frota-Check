rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isBootstrappedAdmin() { return isSignedIn() && request.auth.token.email == 'jp1067107@gmail.com'; }
    function isAdmin() { return isBootstrappedAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/userRoles/$(request.auth.uid))); }

    match /empresas/{empresaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == empresaId;
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == empresaId);
    }

    match /operadores/{opId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    function isValidMachine(data) {
      let isBaseValid = data.keys().hasAll(['name', 'status', 'createdAt', 'updatedAt', 'empresaId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.status in ['active', 'maintenance', 'pendente'] &&
             data.empresaId is string && data.empresaId.size() > 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
      let hasValidPin = !('pin' in data) || (data.pin is string && data.pin.size() > 0 && data.pin.size() <= 10);
      return isBaseValid && hasValidPin && (data.keys().size() == 5 || data.keys().size() == 6);
    }

    function isValidChecklist(data) {
      return data.keys().hasAll(['maquinaId', 'maquinaNome', 'operadorId', 'dataHora', 'status', 'fotos', 'userId', 'empresaId']) &&
             data.keys().size() == 8 &&
             data.maquinaId is string && data.maquinaId.size() > 0 && data.maquinaId.size() <= 128 &&
             data.maquinaNome is string && data.maquinaNome.size() > 0 && data.maquinaNome.size() <= 128 &&
             data.operadorId is string && data.operadorId.size() > 0 && data.operadorId.size() <= 10 &&
             data.dataHora is timestamp &&
             data.status in ['liberada', 'pendente', 'manutencao'] &&
             data.empresaId is string && data.empresaId.size() > 0 &&
             data.fotos is map && 
             data.fotos.keys().hasAll(['painel', 'oleo', 'radiador']) &&
             data.fotos.keys().size() == 3 &&
             data.fotos.painel is string && data.fotos.painel.size() <= 1024 &&
             data.fotos.oleo is string && data.fotos.oleo.size() <= 1024 &&
             data.fotos.radiador is string && data.fotos.radiador.size() <= 1024 &&
             data.userId is string && data.userId == request.auth.uid;
    }

    match /maquinas/{machineId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(machineId) && isValidMachine(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(machineId) && isValidMachine(incoming()) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status', 'updatedAt', 'empresaId', 'pin']);
      allow delete: if isAdmin() && isValidId(machineId);
    }

    match /checklists/{checklistId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(checklistId) && isValidChecklist(incoming()) &&
                    incoming().dataHora == request.time &&
                    exists(/databases/$(database)/documents/maquinas/$(incoming().maquinaId));
      allow update: if false; // Immutable
      allow delete: if isAdmin() && isValidId(checklistId);
    }

    match /userRoles/{userId} {
      allow read: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidId(userId);
      allow update: if false;
      allow delete: if isAdmin() && isValidId(userId);
    }
  }
}

